{
  "name": "Provider cycle",
  "background": [
    {
      "keyword": "Given",
      "text": "the app is running"
    },
    {
      "keyword": "And",
      "text": "the panel is visible"
    }
  ],
  "scenarios": [
    {
      "name": "Ctrl+Tab cycles to the next provider in the list",
      "steps": [
        {
          "keyword": "Given",
          "text": "providers \"\u003cfirst\u003e\" and \"\u003csecond\u003e\" are configured in that order",
          "parameters": [
            "first",
            "second"
          ]
        },
        {
          "keyword": "When",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "Then",
          "text": "the active provider is \"\u003csecond\u003e\"",
          "parameters": [
            "second"
          ]
        }
      ],
      "examples": [
        {
          "first": "Gemini",
          "second": "ChatGPT"
        }
      ]
    },
    {
      "name": "Cycling wraps from the last provider back to the first",
      "steps": [
        {
          "keyword": "Given",
          "text": "providers \"\u003cfirst\u003e\" and \"\u003csecond\u003e\" are configured in that order",
          "parameters": [
            "first",
            "second"
          ]
        },
        {
          "keyword": "When",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "And",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "Then",
          "text": "the active provider is \"\u003cfirst\u003e\"",
          "parameters": [
            "first"
          ]
        }
      ],
      "examples": [
        {
          "first": "Gemini",
          "second": "ChatGPT"
        }
      ]
    },
    {
      "name": "Ctrl+Tab with only one provider configured does nothing",
      "steps": [
        {
          "keyword": "Given",
          "text": "only provider \"Gemini\" is configured"
        },
        {
          "keyword": "When",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "Then",
          "text": "the active provider is \"Gemini\""
        }
      ],
      "examples": []
    },
    {
      "name": "Panel switches to the next provider's web view when Ctrl+Tab is pressed",
      "steps": [
        {
          "keyword": "Given",
          "text": "providers \"\u003cfirst\u003e\" and \"\u003csecond\u003e\" are configured in that order",
          "parameters": [
            "first",
            "second"
          ]
        },
        {
          "keyword": "And",
          "text": "the panel shows the web view for provider \"\u003cfirst\u003e\"",
          "parameters": [
            "first"
          ]
        },
        {
          "keyword": "When",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "Then",
          "text": "the panel shows the web view for provider \"\u003csecond\u003e\"",
          "parameters": [
            "second"
          ]
        }
      ],
      "examples": [
        {
          "first": "Gemini",
          "second": "ChatGPT"
        }
      ]
    },
    {
      "name": "Panel cycles through all three providers in order without skipping",
      "steps": [
        {
          "keyword": "Given",
          "text": "providers \"\u003cp1\u003e\", \"\u003cp2\u003e\", and \"\u003cp3\u003e\" are configured in that order",
          "parameters": [
            "p1",
            "p2",
            "p3"
          ]
        },
        {
          "keyword": "And",
          "text": "the panel shows the web view for provider \"\u003cp1\u003e\"",
          "parameters": [
            "p1"
          ]
        },
        {
          "keyword": "When",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "Then",
          "text": "the panel shows the web view for provider \"\u003cp2\u003e\"",
          "parameters": [
            "p2"
          ]
        },
        {
          "keyword": "When",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "Then",
          "text": "the panel shows the web view for provider \"\u003cp3\u003e\"",
          "parameters": [
            "p3"
          ]
        },
        {
          "keyword": "When",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "Then",
          "text": "the panel shows the web view for provider \"\u003cp1\u003e\"",
          "parameters": [
            "p1"
          ]
        }
      ],
      "examples": [
        {
          "p1": "Gemini",
          "p2": "ChatGPT",
          "p3": "Copilot"
        }
      ]
    },
    {
      "name": "Each provider retains its web session when the user switches away and back",
      "steps": [
        {
          "keyword": "Given",
          "text": "providers \"Gemini\" and \"ChatGPT\" are loaded and signed in"
        },
        {
          "keyword": "When",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "And",
          "text": "the user presses Ctrl+Tab"
        },
        {
          "keyword": "Then",
          "text": "the \"Gemini\" provider is in the same session state as before cycling"
        }
      ],
      "examples": []
    }
  ]
}
